# ─────────────────────────────────────────────
# METATRON — variabili d'ambiente per docker compose
# Copia questo file in `.env` e personalizza se serve:
#     cp .env.example .env
# ─────────────────────────────────────────────

# Database (MariaDB containerizzato)
DB_NAME=metatron
DB_USER=metatron
DB_PASS=123
DB_ROOT_PASS=rootpass

# Ollama — gira NATIVO sul Mac, l'app dentro Docker lo chiama
# tramite host.docker.internal (gestito da Docker Desktop su macOS).
OLLAMA_URL=http://host.docker.internal:11434/api/chat
OLLAMA_MODEL=metatron-qwen
